<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/route_log_screen_bg"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarInbox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/route_log_card_bg"
        android:minHeight="?attr/actionBarSize"
        android:title="@string/inbox_title"
        android:titleTextColor="@color/route_log_text_primary"
        app:subtitle="@string/inbox_subtitle"
        app:subtitleTextColor="@color/route_log_text_secondary" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvInboxConversations"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="16dp" />

        <TextView
            android:id="@+id/tvInboxEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/inbox_empty_state"
            android:textColor="@color/route_log_text_secondary"
            android:textSize="14sp" />
    </FrameLayout>

</LinearLayout>
