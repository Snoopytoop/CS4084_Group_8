rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function self(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function admin() {
      return signedIn()
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function conversationIdHasCurrentUser(conversationId) {
      return signedIn()
          && conversationId.matches('(^|_)' + request.auth.uid + '(_|$)');
    }

    function onlyFieldsChanged(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function postMetadataUnchanged() {
      return request.resource.data.authorUid == resource.data.authorUid
          && request.resource.data.authorName == resource.data.authorName
          && request.resource.data.authorProfileImageUrl == resource.data.authorProfileImageUrl
          && request.resource.data.postType == resource.data.postType
          && request.resource.data.content == resource.data.content
          && request.resource.data.mediaUrl == resource.data.mediaUrl
          && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /users/{userId} {
      allow read: if signedIn();

      allow create: if self(userId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.role == 'user';

      allow update: if admin()
          || (self(userId)
              && request.resource.data.uid == resource.data.uid
              && request.resource.data.role == resource.data.role);

      allow delete: if admin();
    }

    match /posts/{postId} {
      allow read: if signedIn();

      allow create: if signedIn()
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.likesCount == 0
          && request.resource.data.commentsCount == 0
          && request.resource.data.likedBy.size() == 0;

      allow update: if admin()
          || (signedIn()
              && onlyFieldsChanged(['likedBy', 'likesCount', 'commentsCount'])
              && postMetadataUnchanged());

      allow delete: if admin() || resource.data.authorUid == request.auth.uid;

      match /comments/{commentId} {
        allow read: if signedIn();

        allow create: if signedIn()
            && request.resource.data.authorUid == request.auth.uid;

        allow update, delete: if admin() || resource.data.authorUid == request.auth.uid;
      }
    }

    match /routeLogs/{routeLogId} {
      allow read: if admin() || resource.data.authorUid == request.auth.uid;

      allow create: if signedIn()
          && request.resource.data.authorUid == request.auth.uid;

      allow update, delete: if admin() || resource.data.authorUid == request.auth.uid;
    }

    match /belayerPosts/{belayerPostId} {
      allow read: if signedIn();

      allow create: if signedIn()
          && request.resource.data.authorUid == request.auth.uid;

      allow update, delete: if admin() || resource.data.authorUid == request.auth.uid;
    }

    match /blogs/{blogId} {
      allow read: if signedIn();

      allow create: if signedIn()
          && request.resource.data.keys().hasOnly(['authorUid', 'authorName', 'title', 'body', 'createdAt'])
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() > 0
          && request.resource.data.authorName.size() <= 80
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 120
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 6000;

      allow update: if admin()
          || (signedIn()
              && resource.data.authorUid == request.auth.uid
              && request.resource.data.keys().hasOnly(['authorUid', 'authorName', 'title', 'body', 'createdAt'])
              && request.resource.data.authorUid == resource.data.authorUid
              && request.resource.data.authorName is string
              && request.resource.data.authorName.size() > 0
              && request.resource.data.authorName.size() <= 80
              && request.resource.data.title is string
              && request.resource.data.title.size() > 0
              && request.resource.data.title.size() <= 120
              && request.resource.data.body is string
              && request.resource.data.body.size() > 0
              && request.resource.data.body.size() <= 6000);

      allow delete: if admin() || resource.data.authorUid == request.auth.uid;
    }

    match /conversations/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;

      allow create: if signedIn()
          && request.auth.uid in request.resource.data.participants
          && request.resource.data.participants.size() == 2
          && request.resource.data.lastMessageSenderUid == request.auth.uid
          && request.resource.data.lastMessageText.size() > 0;

      allow update: if admin()
          || (signedIn()
              && request.auth.uid in resource.data.participants
              && request.resource.data.participants == resource.data.participants
              && request.resource.data.lastMessageSenderUid == request.auth.uid
              && request.resource.data.lastMessageText.size() > 0);

      allow delete: if admin();

      match /messages/{messageId} {
        allow read: if signedIn()
            && (
              (resource.data.participants is list && request.auth.uid in resource.data.participants)
              || conversationIdHasCurrentUser(conversationId)
            );

        allow create: if signedIn()
            && request.auth.uid in getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
            && request.resource.data.senderUid == request.auth.uid
            && request.resource.data.text.size() > 0
            && request.resource.data.participants is list
            && request.auth.uid in request.resource.data.participants;

        allow update, delete: if admin();
      }
    }

    match /leaderboard/{entryId} {
      allow read: if signedIn();

      allow create: if signedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.seconds >= 0
          && request.resource.data.milliseconds >= 0
          && request.resource.data.milliseconds < 1000
          && request.resource.data.totalMs >= 0;

      allow update, delete: if admin() || resource.data.uid == request.auth.uid;
    }
  }
}
