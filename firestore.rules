rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    match /users/{userId} {
      allow read: if signedIn();

      allow create: if isOwner(userId)
          && request.resource.data.get('role', 'user') == 'user';

      // Allow owner to update anything EXCEPT the 'role' field
      allow update: if isAdmin() || (isOwner(userId)
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])));

      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAdmin() || (signedIn() && resource.data.authorUid == request.author.uid);
      allow delete: if isAdmin() || resource.data.authorUid == request.auth.uid;

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isAdmin() || resource.data.authorUid == request.auth.uid;
      }
    }

    match /routeLogs/{routeLogId} {
      allow read: if isAdmin() || resource.data.authorUid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isAdmin() || resource.data.authorUid == request.auth.uid;
    }

    match /belayerPosts/{belayerPostId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isAdmin() || resource.data.authorUid == request.auth.uid;
    }

    match /blogs/{blogId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAdmin() || (signedIn() && resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() || resource.data.authorUid == request.auth.uid;
    }

    match /conversations/{conversationId} {
      allow read: if signedIn() && (
        conversationId.matches('^' + request.auth.uid + '_.*') ||
        conversationId.matches('.*_' + request.auth.uid + '$') ||
        (resource != null && request.auth.uid in resource.data.participants)
      );
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isAdmin() || (signedIn() && request.auth.uid in resource.data.participants);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    match /leaderboard/{entryId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin() || request.resource.data.uid == request.auth.uid;
    }
  }
}
